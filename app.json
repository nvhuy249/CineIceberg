{
  "expo": {
    "name": "CineIceberg",
    "slug": "cineiceberg",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E252C"
    },
    "scheme": "cineiceberg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.vuhuynguyen.cineiceberg",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.vuhuynguyen.cineiceberg",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1E252C",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E252C",
          "dark": {
            "backgroundColor": "#1E252C"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
